NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
# Service-role key — required for password-protected scenarios (bypasses RLS to read password_hash)
SUPABASE_SERVICE_ROLE_KEY=eyJ...
# Secret used to sign access cookies for password-protected play sessions (12-hour HMAC tokens).
# Falls back to SUPABASE_SERVICE_ROLE_KEY if omitted, or a dev placeholder (not safe for production).
SHARE_LINK_SECRET=a-long-random-string-min-32-chars
# Your deployed app URL — used for OG tags and shareable link generation
NEXT_PUBLIC_APP_URL=https://your-domain.com
# Persistence mode: "supabase" (default) or "local" (localStorage, no auth required)
# Currently unused — all I/O goes through Supabase. Wire up in scenario-store.ts
# when a local-only mode is needed (e.g. offline demo, E2E tests without a DB).
NEXT_PUBLIC_BRANCHLAB_PERSISTENCE=supabase
